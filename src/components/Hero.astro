---
---
<section id="home">
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-tag">
        <span class="hero-dot"></span>
        Available for Freelance
      </div>

      <h1 class="hero-name">
        Yoga<br/>
        <em>Rizky</em>
      </h1>

      <div class="hero-divider"></div>

      <p class="hero-role">IT Support Supervisor · Web Developer · Bali</p>

      <p class="hero-desc">
        Five years managing enterprise IT infrastructure — now building fast, purposeful websites that help small businesses grow online.
      </p>

      <div class="hero-actions">
        <a href="#projects" class="btn-primary">View Work</a>
        <a href="#contact" class="btn-ghost">Get in Touch →</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="stat-n">5+</span>
          <span class="stat-l">Years IT Experience</span>
        </div>
        <div class="hero-stat">
          <span class="stat-n">90%</span>
          <span class="stat-l">Asset Coverage (GLPI)</span>
        </div>
        <div class="hero-stat">
          <span class="stat-n">3×</span>
          <span class="stat-l">Network Capacity Upgraded</span>
        </div>
      </div>
      <div class="hero-note">
        <span class="mono-label">Current Role</span>
        <p>IT Support Supervisor at ICS Travel Group, Bali — Sep 2020 → Present</p>
      </div>
    </div>
  </div>

  <div class="hero-ticker" aria-hidden="true">
    <div class="ticker-track">
      {["Astro", "Tailwind CSS", "Windows Server", "Ubuntu Server", "Docker", "Mikrotik RouterOS", "Google Workspace", "Synology NAS", "GLPI", "Network Planning", "Astro", "Tailwind CSS", "Windows Server", "Ubuntu Server", "Docker", "Mikrotik RouterOS", "Google Workspace", "Synology NAS", "GLPI", "Network Planning"].map(item => (
        <span class="ticker-item">{item} <i>✦</i></span>
      ))}
    </div>
  </div>
</section>

<style>
#home {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  border-bottom: 1px solid var(--border);
  padding-top: 80px;
}

.hero-inner {
  flex: 1;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 0;
}

.hero-left {
  padding: 80px 56px;
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-dim);
  margin-bottom: 40px;
  animation: fadeUp 0.5s ease both 0.1s;
}

.hero-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #22c55e;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50% { opacity:0.5; transform:scale(0.8); }
}

.hero-name {
  font-family: var(--font-display);
  font-size: clamp(64px, 8vw, 108px);
  font-weight: 900;
  line-height: 0.9;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin-bottom: 32px;
  animation: fadeUp 0.6s ease both 0.25s;
}

.hero-name em {
  font-style: italic;
  color: var(--ink-mid);
}

.hero-divider {
  width: 48px;
  height: 2px;
  background: var(--accent-red);
  margin-bottom: 28px;
  animation: fadeUp 0.6s ease both 0.35s;
}

.hero-role {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.08em;
  color: var(--ink-dim);
  margin-bottom: 28px;
  animation: fadeUp 0.6s ease both 0.45s;
}

.hero-desc {
  font-size: 17px;
  color: var(--ink-mid);
  line-height: 1.75;
  max-width: 420px;
  margin-bottom: 48px;
  animation: fadeUp 0.6s ease both 0.55s;
}

.hero-actions {
  display: flex;
  gap: 16px;
  align-items: center;
  animation: fadeUp 0.6s ease both 0.65s;
}

.btn-primary {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--bg);
  background: var(--ink);
  padding: 14px 32px;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-primary:hover { background: var(--accent-red); }

.btn-ghost {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.05em;
  color: var(--ink-mid);
  text-decoration: none;
  border-bottom: 1px solid var(--border-dark);
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.btn-ghost:hover { color: var(--accent-red); border-color: var(--accent-red); }

/* Right side */
.hero-right {
  padding: 80px 56px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 48px;
  background: var(--bg-warm);
}

.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hero-stat {
  display: flex;
  align-items: baseline;
  gap: 20px;
  padding: 24px 0;
  border-bottom: 1px solid var(--border);
  animation: fadeUp 0.6s ease both;
}
.hero-stat:first-child { border-top: 1px solid var(--border); animation-delay: 0.7s; }
.hero-stat:nth-child(2) { animation-delay: 0.85s; }
.hero-stat:nth-child(3) { animation-delay: 1s; }

.stat-n {
  font-family: var(--font-display);
  font-size: 40px;
  font-weight: 900;
  color: var(--ink);
  line-height: 1;
  min-width: 80px;
}

.stat-l {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-dim);
  line-height: 1.4;
}

.hero-note {
  padding: 24px;
  border: 1px solid var(--border);
  background: var(--surface);
  animation: fadeUp 0.6s ease both 1.1s;
}

.mono-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-faint);
  display: block;
  margin-bottom: 8px;
}

.hero-note p {
  font-size: 13px;
  color: var(--ink-mid);
  line-height: 1.5;
}

/* Ticker */
.hero-ticker {
  border-top: 1px solid var(--border);
  padding: 14px 0;
  overflow: hidden;
  background: var(--surface);
}

.ticker-track {
  display: flex;
  white-space: nowrap;
  animation: ticker 30s linear infinite;
}

.ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  padding: 0 28px;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-faint);
}
.ticker-item i { font-style: normal; font-size: 8px; color: var(--accent-red); }

@keyframes ticker {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-left { padding: 48px 24px; border-right: none; border-bottom: 1px solid var(--border); }
  .hero-right { padding: 40px 24px; }
}
</style>
