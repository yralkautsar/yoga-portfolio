---
const projects = [
  {
    num: "01",
    title: "WhatsApp-First Business Site",
    desc: "Conversion-focused landing page untuk UMKM Indonesia. Catalog produk dengan WA order integration, bilingual ID+EN, dan mobile-first design. Tersedia demo untuk bisnis makanan dan fashion.",
    tags: ["Astro", "Tailwind", "WhatsApp API", "Bilingual"],
    url: "https://demo-wa-business-yogarizky.vercel.app",
    status: "Live",
    featured: true
  },
  {
    num: "02",
    title: "Cafe Landing Page",
    desc: "Landing page modern untuk kafe — menu showcase, suasana, galeri foto, dan lokasi dengan performa mobile yang kuat.",
    tags: ["Astro", "Tailwind", "Mobile-First"],
    url: "https://demo-cafe-yogarizky.vercel.app",
    status: "Live",
    featured: false
  },
  {
    num: "03",
    title: "Product Catalog Site",
    desc: "Catalog produk ringan dengan tampilan harga, filter kategori, dan WA order integration untuk toko online sederhana.",
    tags: ["Astro", "Tailwind", "WhatsApp API"],
    url: "https://demo-catalog-yogarizky.vercel.app",
    status: "Live",
    featured: false
  },
  {
    num: "04",
    title: "Wedding Invitation",
    desc: "Undangan pernikahan online elegan dengan countdown timer, galeri foto, RSVP via WhatsApp, amplop digital, dan buku tamu.",
    tags: ["Astro", "Tailwind", "Animation", "WhatsApp API"],
    url: "https://demo-wedding-yogarizky.vercel.app",
    status: "Live",
    featured: false
  }
]
---
<section id="projects">
  <div class="section-header reveal">
    <span class="sec-num">04</span>
    <h2 class="sec-title">Projects</h2>
    <div class="sec-line"></div>
  </div>

  <div class="projects-list">
    {projects.map((p, i) => (
      <a href={p.url} target="_blank" class={`project-row reveal ${p.featured ? "featured" : ""}`} rel="noopener">
        <span class="proj-num">{p.num}</span>
        <div class="proj-main">
          <h3 class="proj-title">{p.title}</h3>
          <p class="proj-desc">{p.desc}</p>
          <div class="proj-tags">
            {p.tags.map(tag => <span class="proj-tag">{tag}</span>)}
          </div>
        </div>
        <div class="proj-meta">
          <span class={`proj-status ${p.status === "Live" ? "live" : "soon"}`}>{p.status}</span>
          <span class="proj-arrow">↗</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
#projects {
  max-width: 1200px;
  margin: 0 auto;
  padding: 120px 56px;
  border-bottom: 1px solid var(--border);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 64px;
}
.sec-num { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; color: var(--accent-red); }
.sec-title { font-family: var(--font-display); font-size: clamp(28px, 4vw, 44px); font-weight: 900; letter-spacing: -0.02em; }
.sec-line { flex: 1; height: 1px; background: var(--border); }

.projects-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.project-row {
  display: grid;
  grid-template-columns: 56px 1fr auto;
  gap: 32px;
  align-items: start;
  padding: 36px 0;
  border-bottom: 1px solid var(--border);
  text-decoration: none;
  color: inherit;
  transition: background 0.2s;
  border-radius: 0;
  position: relative;
}

.project-row::before {
  content: '';
  position: absolute;
  inset: 0 -56px;
  background: transparent;
  transition: background 0.2s;
  pointer-events: none;
}

.project-row:hover::before { background: var(--bg-warm); }
.project-row:hover .proj-arrow { transform: translate(3px, -3px); color: var(--accent-red); }
.project-row:hover .proj-title { color: var(--accent-red); }

.project-row.featured .proj-title {
  font-size: 22px;
}

.proj-num {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  color: var(--ink-faint);
  padding-top: 6px;
}

.proj-main { position: relative; }

.proj-title {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--ink);
  margin-bottom: 8px;
  transition: color 0.2s;
}

.proj-desc {
  font-size: 13px;
  color: var(--ink-dim);
  line-height: 1.65;
  max-width: 560px;
  margin-bottom: 14px;
}

.proj-tags { display: flex; gap: 6px; flex-wrap: wrap; }

.proj-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-dim);
  border: 1px solid var(--border);
  padding: 3px 8px;
}

.proj-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
  padding-top: 4px;
  position: relative;
}

.proj-status {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 10px;
  border: 1px solid;
}
.proj-status.live { color: #16a34a; border-color: #bbf7d0; background: #f0fdf4; }
.proj-status.soon { color: var(--ink-dim); border-color: var(--border); }

.proj-arrow {
  font-size: 18px;
  color: var(--ink-faint);
  transition: transform 0.2s, color 0.2s;
}

@media (max-width: 768px) {
  #projects { padding: 80px 24px; }
  .project-row { grid-template-columns: 1fr; gap: 12px; }
  .proj-num { display: none; }
  .proj-meta { flex-direction: row; align-items: center; justify-content: space-between; }
}
</style>
