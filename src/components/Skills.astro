---
const skillGroups = [
  {
    num: "01",
    title: "Web Development",
    tags: [
      "Astro",
      "Tailwind CSS",
      "HTML5",
      "CSS3",
      "JavaScript",
      "Responsive Design",
    ],
  },
  {
    num: "02",
    title: "Systems & Servers",
    tags: ["Windows Server", "Ubuntu Server", "Docker", "Synology NAS", "GLPI"],
  },
  {
    num: "03",
    title: "Networking",
    tags: [
      "Mikrotik RouterOS",
      "Network Planning",
      "Wi-Fi Roaming",
      "Bandwidth Optimization",
    ],
  },
  {
    num: "04",
    title: "Cloud & Productivity",
    tags: [
      "Google Workspace",
      "Access Management",
      "Remote IT Support",
      "AI-Assisted Workflows",
    ],
  },
  {
    num: "05",
    title: "Leadership & Ops",
    tags: [
      "Team Supervision",
      "Vendor Coordination",
      "IT Documentation",
      "Asset Management",
      "SOP Creation",
    ],
  },
  {
    num: "06",
    title: "Design & Tools",
    tags: [
      "Photoshop",
      "Technical Writing",
      "Process Automation",
      "Cross-dept Communication",
    ],
  },
];
---

<div id="skills">
  <div class="skills-inner">
    <div class="section-header reveal">
      <span class="sec-num">02</span>
      <h2 class="sec-title">Skills</h2>
      <div class="sec-line"></div>
    </div>

    <div class="skills-grid">
      {
        skillGroups.map((group) => (
          <div class="skill-card reveal">
            <span class="card-num">{group.num}</span>
            <h3 class="skill-title">{group.title}</h3>
            <div class="skill-tags">
              {group.tags.map((tag) => (
                <span class="skill-tag">{tag}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  #skills {
    background: var(--bg-warm);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .skills-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 56px;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 64px;
  }
  .sec-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--accent-red);
  }
  .sec-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    letter-spacing: -0.02em;
  }
  .sec-line {
    flex: 1;
    height: 1px;
    background: var(--border-dark);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .skill-card {
    background: var(--surface);
    padding: 36px 32px;
    transition: background 0.2s;
    position: relative;
  }
  .skill-card:hover {
    background: var(--bg-warm);
  }

  .card-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--accent-red);
    display: block;
    margin-bottom: 16px;
  }

  .skill-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--ink-dim);
    border: 1px solid var(--border);
    padding: 4px 10px;
    background: var(--bg);
    transition: all 0.15s;
  }
  .skill-tag:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .skills-inner {
      padding: 80px 24px;
    }
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 901px) and (max-width: 1100px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
